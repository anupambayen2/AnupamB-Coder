# src/training/trainer.py
# ═══════════════════════════════════════════════════════════════════
# AnupamB-Coder-110M Training Script
# 
# Supports all 6 training stages with automatic dataset routing
# Includes NaN protection, smart resume, and progress tracking
#
# Usage:
#   python src/training/trainer.py --stage 3a --resume checkpoints/run_002/best.pt
# ═══════════════════════════════════════════════════════════════════

import sys
import os
ROOT = os.path.dirname(os.path.dirname(
    os.path.dirname(os.path.abspath(__file__))
))
sys.path.insert(0, ROOT)

import math
import time
import json
import glob
import torch
from torch.amp import GradScaler, autocast
from datetime import datetime

from paths import CHECKPOINT_BASE, LOG_DIR, checkpoint_dir, stage_log
from src.model.gpt import GPT, GPTConfig
from src.training.optimizer import build_optimizer


# ═══════════════════════════════════════════════════════════════════
#  TRAINING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

class TrainConfig:
    """Base training configuration"""
    
    # Model architecture
    vocab_size       = 32000
    block_size       = 1024
    n_layer          = 12
    n_head           = 12
    n_embd           = 768
    dropout          = 0.1
    bias             = True
    
    # Training hyperparameters (will be overridden by stage config)
    batch_size       = 2
    grad_accum_steps = 16
    max_steps        = 100_000
    warmup_steps     = 2_000
    learning_rate    = 3e-4
    min_lr           = 3e-5
    weight_decay     = 0.1
    grad_clip        = 0.5
    
    # Evaluation and checkpointing
    eval_interval    = 500
    eval_steps       = 50
    save_interval    = 10_000
    log_interval     = 10
    
    # System settings
    device           = "cuda" if torch.cuda.is_available() else "cpu"
    fp16             = True
    use_8bit_adam    = True
    max_nan_skips    = 10
    
    # Current stage
    stage            = 1


# ═══════════════════════════════════════════════════════════════════
#  STAGE-SPECIFIC CONFIGURATIONS
# ═══════════════════════════════════════════════════════════════════

def apply_stage_config(cfg: TrainConfig, stage):
    """
    Apply stage-specific learning rate and training settings.
    
    Stage 1  : Initial training on base dataset
    Stage 2  : Extended training on large dataset
    Stage 3a : Curated quality data (100K steps)
    Stage 3b : Stack v2 chunk 000-014 (100K steps)
    Stage 3c : Stack v2 chunk 015-029 (100K steps)
    Stage 3d : Stack v2 chunk 030-044 (100K steps)
    Stage 4  : Refinement (150K steps)
    Stage 5  : Fine-tuning (80K steps)
    Stage 6  : Final polish (30K steps)
    """
    
    if stage == 1:
        cfg.learning_rate = 3e-4
        cfg.min_lr        = 3e-5
        cfg.max_steps     = 100_000
        cfg.warmup_steps  = 2_000
        cfg.grad_clip     = 0.5
    
    elif stage == 2:
        cfg.learning_rate = 1e-4
        cfg.min_lr        = 1e-5
        cfg.max_steps     = 400_000
        cfg.warmup_steps  = 1_000
        cfg.grad_clip     = 0.5
    
    # ── Stage 3 Sub-stages ──────────────────────────────────────
    # Lower LR progressively for fine-grained training
    
    elif stage == "3a":
        cfg.learning_rate = 2e-5
        cfg.min_lr        = 2e-6
        cfg.max_steps     = 100_000
        cfg.warmup_steps  = 500
        cfg.grad_clip     = 0.3  # Extra safe for new data
    
    elif stage == "3b":
        cfg.learning_rate = 1.5e-5
        cfg.min_lr        = 1.5e-6
        cfg.max_steps     = 100_000
        cfg.warmup_steps  = 500
        cfg.grad_clip     = 0.3
    
    elif stage == "3c":
        cfg.learning_rate = 1e-5
        cfg.min_lr        = 1e-6
        cfg.max_steps     = 100_000
        cfg.warmup_steps  = 500
        cfg.grad_clip     = 0.3
    
    elif stage == "3d":
        cfg.learning_rate = 8e-6
        cfg.min_lr        = 8e-7
        cfg.max_steps     = 100_000
        cfg.warmup_steps  = 500
        cfg.grad_clip     = 0.3
    
    # ── Later Stages ────────────────────────────────────────────
    
    elif stage == 4:
        cfg.learning_rate = 1e-5
        cfg.min_lr        = 1e-6
        cfg.max_steps     = 150_000
        cfg.warmup_steps  = 500
        cfg.grad_clip     = 0.5
    
    elif stage == 5:
        cfg.learning_rate = 5e-6
        cfg.min_lr        = 5e-7
        cfg.max_steps     = 80_000
        cfg.warmup_steps  = 200
        cfg.grad_clip     = 0.5
    
    elif stage == 6:
        cfg.learning_rate = 2e-6
        cfg.min_lr        = 2e-7
        cfg.max_steps     = 30_000
        cfg.warmup_steps  = 200
        cfg.grad_clip     = 0.5
    
    else:
        raise ValueError(
            f"Unknown stage: {stage}. "
            f"Valid stages: 1, 2, 3a, 3b, 3c, 3d, 4, 5, 6"
        )
    
    return cfg


# ═══════════════════════════════════════════════════════════════════
#  DATASET LOADING
# ═══════════════════════════════════════════════════════════════════

def get_dataloaders(stage, batch_size: int, block_size: int):
    """
    Route to correct dataset builder based on stage.
    
    Stage 1, 2, 4, 5, 6  : Use dataset.py
    Stage 3a, 3b, 3c, 3d : Use dataset_stage3.py
    """
    
    stage3_stages = ["3a", "3b", "3c", "3d"]
    
    if stage in stage3_stages:
        # Stage 3 uses special dataset with sub-stage routing
        from src.data.dataset_stage3 import build_dataloaders_stage3
        return build_dataloaders_stage3(
            stage      = stage,
            batch_size = batch_size,
            block_size = block_size,
        )
    else:
        # Stages 1, 2, 4, 5, 6 use standard dataset
        from src.data.dataset import build_dataloaders
        return build_dataloaders(
            batch_size = batch_size,
            block_size = block_size,
            stage      = stage,
        )


# ═══════════════════════════════════════════════════════════════════
#  LEARNING RATE SCHEDULE
# ═══════════════════════════════════════════════════════════════════

def get_lr(step: int, cfg: TrainConfig) -> float:
    """
    Cosine learning rate schedule with warmup.
    
    Phase 1: Linear warmup from 0 to max LR
    Phase 2: Cosine decay from max LR to min LR
    Phase 3: Stay at min LR after max_steps
    """
    
    # Warmup phase
    if step < cfg.warmup_steps:
        return cfg.learning_rate * (step + 1) / cfg.warmup_steps
    
    # Post-training phase (stay at min)
    if step > cfg.max_steps:
        return cfg.min_lr
    
    # Cosine decay phase
    progress = (step - cfg.warmup_steps) / (cfg.max_steps - cfg.warmup_steps)
    coeff = 0.5 * (1.0 + math.cos(math.pi * progress))
    return cfg.min_lr + coeff * (cfg.learning_rate - cfg.min_lr)


# ═══════════════════════════════════════════════════════════════════
#  EVALUATION
# ═══════════════════════════════════════════════════════════════════

@torch.no_grad()
def evaluate(model, val_loader, cfg: TrainConfig) -> dict:
    """
    Run validation and compute metrics.
    
    Returns:
        dict: Contains val_loss and perplexity
    """
    model.eval()
    losses = []
    
    for i, (x, y) in enumerate(val_loader):
        if i >= cfg.eval_steps:
            break
        
        x, y = x.to(cfg.device), y.to(cfg.device)
        
        with autocast(device_type="cuda", enabled=cfg.fp16):
            _, loss = model(x, y)
        
        if torch.isfinite(loss):
            losses.append(loss.item())
    
    # Handle case where all losses were NaN
    if not losses:
        model.train()
        return {
            "val_loss": float("nan"),
            "perplexity": float("nan"),
        }
    
    avg_loss = sum(losses) / len(losses)
    perplexity = math.exp(min(avg_loss, 20))  # Cap to prevent overflow
    
    model.train()
    return {
        "val_loss": avg_loss,
        "perplexity": perplexity,
    }


# ═══════════════════════════════════════════════════════════════════
#  CHECKPOINT MANAGEMENT
# ═══════════════════════════════════════════════════════════════════

def save_checkpoint(model, optimizer, scaler, step, loss, cfg: TrainConfig):
    """
    Save training checkpoint and manage checkpoint rotation.
    
    Keeps only the 3 most recent checkpoints to save disk space.
    """
    ckpt_dir = checkpoint_dir(cfg.stage)
    os.makedirs(ckpt_dir, exist_ok=True)
    
    path = os.path.join(ckpt_dir, f"step_{step:06d}.pt")
    
    torch.save({
        "step": step,
        "stage": cfg.stage,
        "model_state": model.state_dict(),
        "optim_state": optimizer.state_dict(),
        "scaler_state": scaler.state_dict(),
        "loss": loss,
        "config": {
            "vocab_size": cfg.vocab_size,
            "block_size": cfg.block_size,
            "n_layer": cfg.n_layer,
            "n_head": cfg.n_head,
            "n_embd": cfg.n_embd,
        },
    }, path)
    
    print(f"  [ckpt] saved → {path}")
    
    # Keep only 3 most recent checkpoints
    all_ckpts = sorted(glob.glob(os.path.join(ckpt_dir, "step_*.pt")))
    if len(all_ckpts) > 3:
        for old in all_ckpts[:-3]:
            try:
                os.remove(old)
                print(f"  [ckpt] removed → {os.path.basename(old)}")
            except Exception:
                pass
    
    return path


def load_checkpoint(model, optimizer, scaler, path: str, device: str):
    """
    Load checkpoint and restore training state.
    
    Returns:
        tuple: (step, loss, checkpoint_stage)
    """
    print(f"  [ckpt] loading → {path}")
    
    ckpt = torch.load(path, map_location=device)
    
    # Load model state (handle torch.compile wrapper if present)
    state = ckpt["model_state"]
    state = {k.replace("_orig_mod.", ""): v for k, v in state.items()}
    model.load_state_dict(state, strict=False)
    
    # Load optimizer state
    if optimizer and "optim_state" in ckpt:
        try:
            optimizer.load_state_dict(ckpt["optim_state"])
        except Exception:
            print("  [ckpt] optimizer state skipped — fresh start")
    
    # Load scaler state
    if scaler and "scaler_state" in ckpt:
        scaler.load_state_dict(ckpt["scaler_state"])
    
    step = ckpt.get("step", 0)
    loss = ckpt.get("loss", 0.0)
    ckpt_stage = ckpt.get("stage", 1)
    
    print(f"  [ckpt] resumed step {step}  loss {loss:.4f}  stage {ckpt_stage}")
    
    return step, loss, ckpt_stage


# ═══════════════════════════════════════════════════════════════════
#  LOGGING
# ═══════════════════════════════════════════════════════════════════

class Logger:
    """Training logger with JSON output and console display"""
    
    def __init__(self, stage):
        os.makedirs(LOG_DIR, exist_ok=True)
        self.path = stage_log(stage)
        self.t0 = time.time()
        self.stage = stage
        
        # Write training start event
        with open(self.path, "a") as f:
            f.write(json.dumps({
                "event": "training_start",
                "stage": str(stage),
                "ts": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            }) + "\n")
        
        print(f"  Log file            : {self.path}")
    
    def write(self, data: dict):
        """Write log entry to file"""
        data["ts"] = datetime.now().strftime("%H:%M:%S")
        data["min"] = round((time.time() - self.t0) / 60, 1)
        
        try:
            with open(self.path, "a") as f:
                f.write(json.dumps(data) + "\n")
        except Exception as e:
            print(f"  [log error] {e}")
    
    def print_step(self, step, loss, lr, dt_ms, vram_gb=None, max_steps=None):
        """Print formatted training step info"""
        
        # VRAM usage
        vram_s = f"  vram {vram_gb:.1f}GB" if vram_gb else ""
        
        # Time estimate
        time_s = ""
        if max_steps:
            elapsed_min = (time.time() - self.t0) / 60
            remaining_min = ((max_steps - step) * dt_ms) / 1000 / 60
            
            elapsed_s = (
                f"{elapsed_min:.0f}m" if elapsed_min < 60 
                else f"{elapsed_min/60:.1f}h"
            )
            remain_s = (
                f"~{remaining_min:.0f}m left" if remaining_min < 60 
                else f"~{remaining_min/60:.1f}h left"
            )
            time_s = f"  {elapsed_s} elapsed  {remain_s}"
        
        print(
            f"  step {step:>7} | "
            f"loss {loss:.4f} | "
            f"lr {lr:.2e} | "
            f"{dt_ms:5.0f} ms/step"
            f"{vram_s}"
            f"{time_s}"
        )


def get_vram_gb():
    """Get current GPU VRAM usage in GB"""
    if torch.cuda.is_available():
        return torch.cuda.memory_allocated() / 1024**3
    return None


# ═══════════════════════════════════════════════════════════════════
#  MAIN TRAINING FUNCTION
# ═══════════════════════════════════════════════════════════════════

def train(resume_from=None, stage=1, max_steps=None):
    """
    Main training loop with NaN protection and smart resume.
    
    Args:
        resume_from: Path to checkpoint to resume from
        stage: Training stage (1, 2, 3a, 3b, 3c, 3d, 4, 5, 6)
        max_steps: Override max steps (optional)
    """
    
    # Initialize config
    cfg = TrainConfig()
    cfg.stage = stage
    cfg = apply_stage_config(cfg, stage)
    
    if max_steps is not None:
        cfg.max_steps = max_steps
    
    logger = Logger(stage)
    
    # Print training header
    print(f"\n{'═'*70}")
    print(f"  ANUPAMB-CODER-110M TRAINING — STAGE {stage}")
    print(f"{'═'*70}")
    print(f"  Device              : {cfg.device}")
    print(f"  Model               : {cfg.n_layer}L · {cfg.n_embd}D · {cfg.n_head}H · {cfg.block_size} ctx")
    print(f"  Parameters          : ~110M")
    print(f"  Effective batch     : {cfg.batch_size} × {cfg.grad_accum_steps} = {cfg.batch_size * cfg.grad_accum_steps}")
    print(f"  Max steps           : {cfg.max_steps:,}")
    print(f"  Warmup steps        : {cfg.warmup_steps:,}")
    print(f"  Learning rate       : {cfg.learning_rate}")
    print(f"  Min LR              : {cfg.min_lr}")
    print(f"  Grad clip           : {cfg.grad_clip}  ← NaN safe")
    print(f"  8-bit Adam          : {cfg.use_8bit_adam}")
    print(f"  Mixed precision     : {cfg.fp16}")
    print(f"  NaN protection      : enabled (max {cfg.max_nan_skips} consecutive)")
    print(f"  Checkpoint dir      : {checkpoint_dir(stage)}")
    print(f"{'─'*70}\n")
    
    # ── Load Dataset ───────────────────────────────────────────────
    train_loader, val_loader, vocab_size = get_dataloaders(
        stage=stage,
        batch_size=cfg.batch_size,
        block_size=cfg.block_size,
    )
    
    # ── Create Model ───────────────────────────────────────────────
    model = GPT(GPTConfig(
        vocab_size=vocab_size,
        block_size=cfg.block_size,
        n_layer=cfg.n_layer,
        n_head=cfg.n_head,
        n_embd=cfg.n_embd,
        dropout=cfg.dropout,
        bias=cfg.bias,
    )).to(cfg.device)
    
    total_params = model.get_num_params()
    print(f"  Model params        : {total_params:,}")
    
    vram = get_vram_gb()
    if vram:
        print(f"  VRAM after load     : {vram:.2f} GB / 8.00 GB")
        print(f"  VRAM headroom       : {8.0 - vram:.2f} GB\n")
    
    # ── Create Optimizer ───────────────────────────────────────────
    optimizer = build_optimizer(
        model,
        cfg.learning_rate,
        cfg.weight_decay,
        use_8bit=cfg.use_8bit_adam,
    )
    scaler = GradScaler(enabled=cfg.fp16)
    
    # ── Smart Resume ───────────────────────────────────────────────
    start_step = 0
    
    if resume_from and os.path.exists(resume_from):
        start_step, _, ckpt_stage = load_checkpoint(
            model, optimizer, scaler, resume_from, cfg.device
        )
        
        # Check if same stage or different stage
        if str(ckpt_stage) == str(stage):
            # Same stage — continue from saved step
            print(f"  Resuming stage {stage} from step {start_step}  ✅")
            print(f"  Steps remaining : {cfg.max_steps - start_step:,} / {cfg.max_steps:,}")
        else:
            # Different stage — reset step counter
            print(f"  Stage change: {ckpt_stage} → {stage}")
            print(f"  Resetting step counter for new stage")
            start_step = 0
    
    # Note: torch.compile disabled on Windows
    print("  torch.compile       : disabled (Windows)")
    model.train()
    
    print(f"\n{'─'*70}")
    print(f"  Stage {stage} — step {start_step:,} → {cfg.max_steps:,}")
    print(f"{'─'*70}\n")
    
    # ── Training Loop ──────────────────────────────────────────────
    train_iter = iter(train_loader)
    best_val_loss = float("inf")
    step = start_step
    t0 = time.time()
    nan_skip_count = 0
    total_nan_skipped = 0
    optimizer.zero_grad()
    
    while step < cfg.max_steps:
        
        # ── Learning Rate ──────────────────────────────────────────
        lr = get_lr(step, cfg)
        for g in optimizer.param_groups:
            g["lr"] = lr
        
        # ── Gradient Accumulation with NaN Protection ─────────────
        loss_accum = 0.0
        skip_step = False
        
        for _ in range(cfg.grad_accum_steps):
            # Get batch
            try:
                x, y = next(train_iter)
            except StopIteration:
                train_iter = iter(train_loader)
                x, y = next(train_iter)
            
            x, y = x.to(cfg.device), y.to(cfg.device)
            
            # Forward pass
            with autocast(device_type="cuda", enabled=cfg.fp16):
                _, loss = model(x, y)
                loss = loss / cfg.grad_accum_steps
            
            # NaN check
            if not torch.isfinite(loss):
                print(f"\n  [NaN] loss={loss.item()} at step {step} — skipping batch")
                optimizer.zero_grad()
                skip_step = True
                nan_skip_count += 1
                total_nan_skipped += 1
                
                # Emergency stop if too many consecutive NaN
                if nan_skip_count >= cfg.max_nan_skips:
                    print(f"\n  [EMERGENCY STOP] {nan_skip_count} consecutive NaN!")
                    print(f"  Resume from best checkpoint:")
                    print(f"  python src/training/trainer.py --stage {stage} --resume {checkpoint_dir(stage)}/best.pt")
                    return
                break
            
            # Backward pass
            scaler.scale(loss).backward()
            loss_accum += loss.item()
        
        if skip_step:
            continue
        
        # Reset NaN counter on successful step
        nan_skip_count = 0
        
        # ── Gradient Clipping and Optimizer Step ──────────────────
        scaler.unscale_(optimizer)
        grad_norm = torch.nn.utils.clip_grad_norm_(
            model.parameters(), cfg.grad_clip
        )
        
        # Check for NaN gradients
        if not torch.isfinite(grad_norm):
            print(f"\n  [NaN grad] norm={grad_norm.item()} at step {step} — skipping")
            optimizer.zero_grad()
            scaler.update()
            nan_skip_count += 1
            total_nan_skipped += 1
            
            if nan_skip_count >= cfg.max_nan_skips:
                print(f"\n  [EMERGENCY STOP] {nan_skip_count} NaN grads!")
                print(f"  Resume from best checkpoint:")
                print(f"  python src/training/trainer.py --stage {stage} --resume {checkpoint_dir(stage)}/best.pt")
                return
            continue
        
        scaler.step(optimizer)
        scaler.update()
        optimizer.zero_grad()
        
        step += 1
        dt_ms = (time.time() - t0) * 1000
        t0 = time.time()
        
        # ── Logging ────────────────────────────────────────────────
        if step % cfg.log_interval == 0:
            vram = get_vram_gb()
            logger.print_step(
                step, loss_accum, lr, dt_ms, vram, max_steps=cfg.max_steps
            )
            logger.write({
                "step": step,
                "stage": str(stage),
                "train_loss": round(loss_accum, 4),
                "lr": round(lr, 8),
                "grad_norm": round(grad_norm.item(), 4),
                "dt_ms": round(dt_ms, 1),
                "vram_gb": round(vram, 2) if vram else None,
                "nan_skipped": total_nan_skipped,
            })
        
        # ── Evaluation ─────────────────────────────────────────────
        if step % cfg.eval_interval == 0:
            metrics = evaluate(model, val_loader, cfg)
            val_loss = metrics["val_loss"]
            perplexity = metrics["perplexity"]
            
            print(f"\n  ── Eval @ step {step} (stage {stage}) {'─'*30}")
            
            if not math.isfinite(val_loss):
                print(f"     val_loss   : NaN ← model corrupted!")
                print(f"     Stop and resume from best.pt")
                print()
            else:
                print(f"     val_loss   : {val_loss:.4f}")
                print(f"     perplexity : {perplexity:.2f}")
                
                if total_nan_skipped > 0:
                    print(f"     nan skipped: {total_nan_skipped} total")
                
                # Save best checkpoint
                if val_loss < best_val_loss:
                    best_val_loss = val_loss
                    best_path = os.path.join(checkpoint_dir(stage), "best.pt")
                    os.makedirs(checkpoint_dir(stage), exist_ok=True)
                    
                    torch.save({
                        "step": step,
                        "stage": stage,
                        "model_state": model.state_dict(),
                        "loss": best_val_loss,
                        "config": {
                            "vocab_size": cfg.vocab_size,
                            "block_size": cfg.block_size,
                            "n_layer": cfg.n_layer,
                            "n_head": cfg.n_head,
                            "n_embd": cfg.n_embd,
                        },
                    }, best_path)
                    print(f"     new best   → {best_path}")
                
                print()
            
            logger.write({
                "step": step,
                "stage": str(stage),
                "val_loss": round(val_loss, 4) if math.isfinite(val_loss) else None,
                "perplexity": round(perplexity, 2) if math.isfinite(perplexity) else None,
                "nan_skipped": total_nan_skipped,
            })
        
        # ── Checkpoint ─────────────────────────────────────────────
        if step % cfg.save_interval == 0:
            save_checkpoint(model, optimizer, scaler, step, loss_accum, cfg)
    
    # ── Training Complete ──────────────────────────────────────────
    print(f"\n{'═'*70}")
    print(f"  STAGE {stage} COMPLETE!")
    print(f"{'═'*70}")
    print(f"  Total steps      : {step:,}")
    print(f"  Best val loss    : {best_val_loss:.4f}")
    print(f"  NaN batches skip : {total_nan_skipped}")
    print(f"  Checkpoints      : {checkpoint_dir(stage)}")
    print(f"{'═'*70}\n")


# ═══════════════════════════════════════════════════════════════════
#  ENTRY POINT
# ═══════════════════════════════════════════════════════════════════

if __name__ == "__main__":
    import argparse
    
    parser = argparse.ArgumentParser(
        description="Train AnupamB-Coder-110M",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # Start Stage 1 from scratch
  python src/training/trainer.py --stage 1
  
  # Resume Stage 2 from checkpoint
  python src/training/trainer.py --stage 2 --resume checkpoints/run_001/best.pt
  
  # Start Stage 3a from Stage 2 checkpoint
  python src/training/trainer.py --stage 3a --resume checkpoints/run_002/best.pt
  
  # Continue Stage 3a from its own checkpoint
  python src/training/trainer.py --stage 3a --resume checkpoints/run_003/latest.pt
  
Stages:
  1    : Initial training (100K steps)
  2    : Extended training (400K steps)
  3a   : Curated quality data (100K steps)
  3b   : Stack v2 chunk 000-014 (100K steps)
  3c   : Stack v2 chunk 015-029 (100K steps)
  3d   : Stack v2 chunk 030-044 (100K steps)
  4    : Refinement (150K steps)
  5    : Fine-tuning (80K steps)
  6    : Final polish (30K steps)
        """
    )
    
    parser.add_argument(
        "--resume",
        type=str,
        default=None,
        help="Path to checkpoint to resume from"
    )
    
    parser.add_argument(
        "--stage",
        type=str,
        default="1",
        help="Training stage: 1, 2, 3a, 3b, 3c, 3d, 4, 5, 6"
    )
    
    parser.add_argument(
        "--max_steps",
        type=int,
        default=None,
        help="Override max steps for this run"
    )
    
    args = parser.parse_args()
    
    # Convert numeric stages to int
    stage = args.stage
    if stage.isdigit():
        stage = int(stage)
    
    # Start training
    train(
        resume_from=args.resume,
        stage=stage,
        max_steps=args.max_steps,
    )
